{% import "default/_macros.yaml.jinja" as macros -%}
apiVersion: v1
kind: Service
metadata:
  generateName: "gs-{{gameType | lower}}-"
  labels:
    {{ macros::standard_labels() | indent(prefix="    ") }}
spec:
  selector:
    {{ macros::service_selector() | indent(prefix="    ")}}
  type: LoadBalancer
  ports:
    - port: 22
      targetPort: 22
      protocol: "TCP"
      name: sftp
    {%- for servicePort in ports %}
    {%- if servicePort.protocol == 'Both' %}
    - port: {{servicePort.port}}
      targetPort: {{servicePort.port}}
      protocol: "TCP"
      name: "{{servicePort.port}}-tcp"
    - port: {{servicePort.port}}
      targetPort: {{servicePort.port}}
      name: "{{servicePort.port}}-udp"
      protocol: "UDP"
    {%- else %}
    - port: {{servicePort.port}}
      targetPort: {{servicePort.port}}
      protocol: "{{servicePort.protocol | addslashes }}"
      name: "{{servicePort.port}}-{{servicePort.protocol | addslashes | lower}}"
    {%- endif %}
    {%- endfor %}
